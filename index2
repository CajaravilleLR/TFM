<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&display=swap" rel="stylesheet">
<style>
  :root {
    /* Paleta sanitaria clara — blueprint clínico */
    --bg:        #f5f3ec;            /* marfil cálido */
    --bg-2:      #ebe7dc;            /* marfil más oscuro para zonas */
    --paper:     #fbfaf5;            /* papel */
    --ink:       #1a2733;            /* tinta principal — gris azulado */
    --ink-2:     #4a5764;            /* tinta secundaria */
    --ink-3:     #7d8a96;            /* tinta terciaria / metadatos */
    --rule:      #d4cfc0;            /* línea / regla */
    --rule-2:    #c2bca8;            /* línea fuerte */

    /* Acentos — verde sanitario sage + azul clínico, mismo chroma/L */
    --sage:      oklch(0.55 0.08 165);   /* verde sanitario */
    --sage-soft: oklch(0.92 0.04 165);
    --clinic:    oklch(0.55 0.08 230);   /* azul clínico */
    --clinic-soft: oklch(0.92 0.04 230);
    --warn:      oklch(0.62 0.10 60);    /* ámbar — para alertas, patrones */
    --warn-soft: oklch(0.93 0.05 60);

    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    --font-serif: 'Fraunces', Georgia, serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--ink);
    overflow: hidden;
    font-feature-settings: "ss01", "cv11";
    -webkit-font-smoothing: antialiased;
  }

  /* Patrón de fondo — papel cuadriculado muy sutil */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      linear-gradient(var(--rule) 1px, transparent 1px),
      linear-gradient(90deg, var(--rule) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }
  body::after {
    content: '';
    position: fixed; inset: 0;
    background:
      radial-gradient(ellipse 120% 60% at 50% 100%, rgba(0,0,0,0.04), transparent 60%),
      radial-gradient(ellipse 100% 50% at 50% 0%, rgba(0,0,0,0.025), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Header persistente ───────────────────────────────────── */
  .topbar {
    position: fixed; top: 0; left: 0; right: 0;
    height: 56px;
    background: rgba(245, 243, 236, 0.85);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--rule);
    z-index: 100;
    display: flex; align-items: center;
    padding: 0 24px;
    gap: 18px;
  }
  .brand {
    display: none;
    align-items: baseline; gap: 10px;
    font-size: 12px; letter-spacing: 0.02em;
  }
  .brand .mark {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--sage);
    border: 1px solid var(--sage);
    padding: 2px 6px;
    border-radius: 3px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .brand .title {
    font-weight: 600;
    color: var(--ink);
  }
  .brand .meta {
    color: var(--ink-3);
    font-size: 11px;
  }

  .crumb {
    flex: 1;
    display: flex; align-items: center; gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }
  .crumb .sep { opacity: 0.5; }
  .crumb .here { color: var(--ink); font-weight: 500; }
  .crumb a {
    color: var(--ink-3);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.15s;
  }
  .crumb a:hover { color: var(--sage); }

  .top-actions { display: none; gap: 8px; align-items: center; }
  .kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-2);
    border: 1px solid var(--rule-2);
    background: var(--paper);
    border-radius: 3px;
    padding: 2px 6px;
    box-shadow: 0 1px 0 var(--rule);
  }
  .top-action-btn {
    border: 1px solid var(--rule-2);
    background: var(--paper);
    color: var(--ink-2);
    font-family: var(--font-mono);
    font-size: 10.5px;
    padding: 5px 10px;
    border-radius: 3px;
    cursor: pointer;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: all 0.15s;
  }
  .top-action-btn:hover {
    border-color: var(--sage);
    color: var(--sage);
  }
  .top-action-btn.active {
    border-color: var(--sage);
    background: var(--sage-soft);
    color: var(--sage);
  }
  .map-canvas.editing .node {
    cursor: move;
  }
  .map-canvas.editing .node .node-card {
    box-shadow: 4px 4px 0 var(--warn);
    border-color: var(--warn);
    border-style: dashed;
  }
  .map-canvas.editing .node[data-id="user"] .node-card {
    border-color: var(--warn);
  }
  .node.dragging .node-card {
    opacity: 0.85;
    box-shadow: 6px 6px 0 var(--ink) !important;
  }

  /* ── Stage / vistas ──────────────────────────────────────── */
  .stage {
    position: fixed;
    top: 56px; left: 0; right: 0; bottom: 0;
    overflow: hidden;
    z-index: 1;
  }
  .view {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transform: scale(0.96);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), visibility 0.5s;
    overflow-y: auto;
    overflow-x: hidden;
    pointer-events: none;
    z-index: 1;
  }
  .view.active {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
    transition-delay: 0.05s;
    pointer-events: auto;
    z-index: 2;
  }
  .view.zoom-out {
    transform: scale(1.08);
    opacity: 0;
  }

  /* ══════════════════════════════════════════════════════════ */
  /* VISTA MAPA — diagrama vivo de la arquitectura              */
  /* ══════════════════════════════════════════════════════════ */
  #view-map {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }
  .map-header {
    text-align: center;
    padding: 26px 24px 14px;
    flex-shrink: 0;
  }
  .map-header .eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--sage);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 14px;
  }
  .map-header h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 38px;
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--ink);
    max-width: 1080px;
    margin: 0 auto;
  }
  .map-header h1 em {
    font-style: italic;
    color: var(--sage);
    font-weight: 500;
  }
  .map-header .sub {
    margin-top: 12px;
    font-size: 16px;
    color: var(--ink-2);
    max-width: 820px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }
  .map-hint {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--ink-3);
    margin-top: 14px;
    letter-spacing: 0.05em;
  }
  .map-hint .pulse-dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--sage);
    margin-right: 6px;
    vertical-align: middle;
    animation: pulseDot 2s infinite;
  }
  @keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.35; transform: scale(0.7); }
  }

  /* canvas wrapper centers the fixed-size diagram and allows horizontal
     scrolling on narrower viewports — Safari mis-maps clicks when canvas
     is `transform: scale`d, so we keep it at native size. */
  .map-canvas-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px 24px 28px;
    min-height: 580px;
    overflow: auto;
  }
  /* fixed-size inner — nodes use absolute px positions tied to viewBox */
  .map-canvas {
    position: relative;
    width: 1440px;
    height: 620px;
    flex-shrink: 0;
  }
  .map-svg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    overflow: visible;
  }
  .map-svg .conn {
    fill: none;
    stroke: var(--ink-2);
    stroke-width: 1.2;
    stroke-dasharray: 4 4;
    opacity: 0.45;
  }
  .map-svg .conn-solid {
    stroke-dasharray: none;
    opacity: 0.5;
  }
  .map-svg .conn-label {
    font-family: var(--font-mono);
    font-size: 12px;
    fill: var(--ink-2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    pointer-events: none;
  }
  .packet {
    fill: var(--sage);
    filter: drop-shadow(0 0 4px rgba(32, 138, 124, 0.4));
  }

  .node {
    position: absolute;
    transform: translate(-50%, -50%);
    cursor: pointer;
    user-select: none;
  }
  .node-card {
    background: var(--paper);
    border: 1.5px solid var(--ink);
    border-radius: 9px;
    padding: 18px 22px;
    min-width: 210px;
    text-align: center;
    transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    box-shadow: 5px 5px 0 var(--ink);
  }
  .node:hover .node-card {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--sage);
    border-color: var(--sage);
  }
  .node-card .id {
    position: absolute;
    top: -9px; left: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    background: var(--bg);
    color: var(--ink-3);
    padding: 0 7px;
    letter-spacing: 0.1em;
  }
  .node-glyph {
    width: 44px; height: 44px;
    margin: 0 auto 10px;
    display: flex; align-items: center; justify-content: center;
  }
  .node-glyph svg { width: 100%; height: 100%; }
  .node-name {
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .node-sub {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--ink-3);
    margin-top: 5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .node-stat {
    margin-top: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--sage);
    font-weight: 500;
  }

  .node[data-id="user"] .node-card {
    background: var(--bg-2);
    border-style: dashed;
    box-shadow: 4px 4px 0 var(--rule-2);
  }
  .node[data-id="user"]:hover .node-card {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--sage);
    border-color: var(--sage);
  }
  .node[data-id="user"] { cursor: pointer; }

  .node-rag .node-card,
  .node-web .node-card {
    min-width: 260px;
  }
  .node-rag .node-card { background: var(--sage-soft); }
  .node-gpt .node-card { background: var(--clinic-soft); }
  .node-web .node-card { background: var(--paper); }
  .node-db  .node-card { background: var(--paper); }
  .node-dash .node-card { background: var(--warn-soft); }

  /* Legend strip */
  .map-legend {
    position: absolute;
    bottom: -6px; left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 24px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--bg);
    padding: 0 12px;
  }
  .map-legend .lg {
    display: flex; align-items: center; gap: 8px;
  }
  .map-legend .swatch {
    width: 14px; height: 8px;
    border: 1px solid var(--ink-2);
  }
  .map-legend .swatch.dashed { border-style: dashed; }
  .map-legend .swatch.solid  { background: var(--ink-2); }
  .map-legend .swatch.live   { background: var(--sage); border-color: var(--sage); }

  /* author plate — placed at the bottom of the view, below canvas */
  .map-footer {
    margin: 0 40px 24px;
    flex-shrink: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }
  .author-plate {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    line-height: 1.7;
    border-left: 2px solid var(--sage);
    padding-left: 12px;
  }
  .author-plate strong {
    color: var(--ink);
    font-weight: 600;
  }

  .map-cta-wrap {
    display: none;
  }
  .map-cta {
    appearance: none;
    background: var(--paper);
    border: 1px solid var(--ink);
    border-radius: 6px;
    padding: 12px 18px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-sans);
    color: var(--ink);
    box-shadow: 4px 4px 0 var(--ink);
    transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .map-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--sage);
    border-color: var(--sage);
  }
  .map-cta-id {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-right: 14px;
    border-right: 1px solid var(--rule-2);
  }
  .map-cta-label {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .map-cta-arrow {
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--sage);
    transition: transform 0.2s;
  }
  .map-cta:hover .map-cta-arrow {
    transform: translateX(3px);
  }

  /* ══════════════════════════════════════════════════════════ */
  /* HABITACIONES — layout común                                */
  /* ══════════════════════════════════════════════════════════ */
  .room {
    padding: 28px 56px 60px;
    max-width: 1480px;
    margin: 0 auto;
  }
  /* Rooms scale gracefully with viewport via natural CSS — no zoom hack
     (CSS `zoom` had inconsistent hit-box behaviour in fullscreen) */
  .view:not(#view-map) {
    /* zoom removed — was causing click mis-routing in fullscreen */
  }
  .room-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 28px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--rule);
  }
  .room-title-block {
    flex: 1;
  }
  .room-eyebrow {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--sage);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 10px;
  }
  .room-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 38px;
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .room-title em {
    font-style: italic;
    color: var(--sage);
  }
  .room-lede {
    font-size: 14.5px;
    color: var(--ink-2);
    line-height: 1.6;
    max-width: 640px;
  }
  .room-aside {
    width: 280px;
    flex-shrink: 0;
    border-left: 1px solid var(--rule);
    padding-left: 20px;
    font-size: 12px;
    color: var(--ink-2);
    line-height: 1.65;
  }
  .room-aside .label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 4px;
    display: block;
  }
  .room-aside .value {
    color: var(--ink);
    font-weight: 500;
    margin-bottom: 10px;
  }

  /* shared bits */
  .stat-tile {
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 16px 18px;
    border-radius: 6px;
  }
  .stat-tile .n {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 500;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .stat-tile .l {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    margin-top: 6px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .stat-tile .src {
    font-size: 11px;
    color: var(--ink-2);
    margin-top: 4px;
    font-style: italic;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-2);
    border: 1px solid var(--rule-2);
    padding: 3px 8px;
    border-radius: 100px;
    letter-spacing: 0.04em;
  }
  .pill.sage { color: var(--sage); border-color: var(--sage); background: var(--sage-soft); }
  .pill.clinic { color: var(--clinic); border-color: var(--clinic); background: var(--clinic-soft); }
  .pill.warn { color: var(--warn); border-color: var(--warn); background: var(--warn-soft); }

  /* Back / nav buttons floating in rooms */
  .room-back {
    position: fixed;
    top: 12px; right: 24px;
    z-index: 110;
    background: var(--paper);
    border: 1px solid var(--rule-2);
    color: var(--ink-2);
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 7px 12px;
    border-radius: 4px;
    cursor: pointer;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: none;
    align-items: center;
    gap: 6px;
    transition: all 0.15s;
    box-shadow: 0 1px 0 var(--rule);
  }
  .room-back.show { display: inline-flex; }
  .room-back:hover {
    border-color: var(--sage);
    color: var(--sage);
  }

  .room-nav {
    position: fixed;
    bottom: 18px; right: 24px;
    z-index: 50;
    display: none;
    gap: 6px;
  }
  .room-nav.show { display: flex; }
  .room-nav button {
    background: var(--paper);
    border: 1px solid var(--rule-2);
    color: var(--ink-2);
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 7px 11px;
    border-radius: 4px;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: all 0.15s;
  }
  .room-nav button:hover {
    border-color: var(--sage);
    color: var(--sage);
  }
  .room-nav .label {
    background: transparent;
    border: none;
    color: var(--ink-3);
    cursor: default;
  }

  /* ══════════ DEMO ROOM ══════════ */
  .demo-room .room-head {
    margin-bottom: 18px;
    padding-bottom: 16px;
  }
  .demo-meta {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 28px;
    margin-bottom: 22px;
    padding: 18px 0 22px;
    border-bottom: 1px solid var(--rule);
  }
  .demo-meta-col { min-width: 0; }
  .demo-meta-k {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 6px;
  }
  .demo-meta-v {
    font-size: 13.5px;
    color: var(--ink);
    line-height: 1.55;
    font-weight: 500;
  }
  .video-frame {
    width: 100%;
    background: #000;
    border: 1px solid var(--rule-2);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 12px 28px rgba(0,0,0,0.08);
  }
  .video-aspect {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
  }
  .video-aspect iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }
  .video-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 10px 16px;
    background: var(--bg-2);
    border-top: 1px solid var(--rule);
  }
  .video-ext {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-2);
    text-decoration: none;
    border: 1px solid var(--rule-2);
    background: var(--paper);
    padding: 5px 10px;
    border-radius: 3px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: all 0.15s;
  }
  .video-ext:hover {
    border-color: var(--sage);
    color: var(--sage);
  }

  /* ══════════ RAG ROOM specific ══════════ */
  .rag-meta-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    width: 100%;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--rule);
  }
  .rag-meta-cell {
    display: flex;
    flex-direction: column;
  }
  .rag-meta-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 6px;
    font-weight: 500;
  }
  .rag-meta-value {
    color: var(--ink);
    font-weight: 500;
    font-size: 13px;
    line-height: 1.5;
  }
  .rag-meta-value.soft {
    color: var(--ink-2);
    font-weight: 400;
    font-size: 12px;
    line-height: 1.55;
  }
  .rag-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 36px;
  }
  .rag-collections {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 8px;
  }
  .coll-mini {
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: 14px 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .coll-mini-num {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 500;
    color: var(--sage);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .coll-mini-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 4px;
  }
  .coll-mini-name {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--ink);
    margin-top: 8px;
    line-height: 1.3;
  }
  .coll-card {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: 14px 18px;
    border-radius: 6px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 16px;
    align-items: center;
    transition: all 0.18s;
    cursor: default;
  }
  .coll-card[data-clickable="true"] { cursor: pointer; }
  .coll-card[data-clickable="true"]:hover {
    border-color: var(--sage);
    background: var(--sage-soft);
  }
  .coll-icon {
    width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
    color: var(--ink);
  }
  .coll-name {
    font-size: 13.5px;
    font-weight: 600;
  }
  .coll-desc {
    font-size: 11.5px;
    color: var(--ink-2);
    margin-top: 2px;
    line-height: 1.5;
  }
  .coll-num {
    font-family: var(--font-serif);
    font-size: 30px;
    font-weight: 500;
    color: var(--sage);
    line-height: 1;
  }
  .coll-num-label {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  /* RAG cronología */
  .timeline {
    position: relative;
    padding-left: 36px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 11px; top: 6px; bottom: 6px;
    width: 2px;
    background: var(--rule-2);
  }
  .tl-item {
    position: relative;
    margin-bottom: 18px;
  }
  .tl-dot {
    position: absolute;
    left: -30px; top: 4px;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: var(--paper);
    border: 2px solid var(--sage);
  }
  .tl-item.done .tl-dot {
    background: var(--sage);
  }
  .tl-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 2px;
  }
  .tl-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .tl-desc {
    font-size: 12.5px;
    color: var(--ink-2);
    line-height: 1.55;
  }
  .tl-tags {
    display: flex; flex-wrap: wrap; gap: 4px;
    margin-top: 6px;
  }

  /* Patrones drawer */
  .drawer {
    position: fixed;
    top: 56px; right: 0; bottom: 0;
    width: 0;
    background: var(--paper);
    border-left: 1px solid var(--rule-2);
    box-shadow: -8px 0 24px rgba(0,0,0,0.04);
    z-index: 80;
    overflow-y: auto;
    transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .drawer.open { width: min(620px, 60vw); }
  .drawer-inner { padding: 30px 32px; opacity: 0; transition: opacity 0.3s 0.15s; }
  .drawer.open .drawer-inner { opacity: 1; }
  .drawer-close {
    position: absolute;
    top: 16px; right: 16px;
    background: transparent;
    border: 1px solid var(--rule-2);
    color: var(--ink-2);
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 5px 10px;
    border-radius: 3px;
    cursor: pointer;
  }
  .drawer-close:hover { border-color: var(--ink); color: var(--ink); }
  .drawer h3 {
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 500;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .drawer .sub {
    font-size: 12.5px;
    color: var(--ink-2);
    margin-bottom: 20px;
    line-height: 1.55;
  }
  .crit-row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px dotted var(--rule-2);
    font-size: 12.5px;
  }
  .crit-row:last-child { border-bottom: none; }
  .crit-row .k {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding-top: 1px;
  }
  .crit-row .v { color: var(--ink-2); line-height: 1.55; }
  .crit-row .v strong { color: var(--ink); font-weight: 600; }

  /* ══════════ INFRAESTRUCTURA LOCAL ══════════ */
  .infra-section {
    margin-top: 38px;
    padding-top: 28px;
    border-top: 1px dashed var(--rule-2);
  }
  .infra-title {
    margin-bottom: 22px;
    font-size: 13px;
  }
  .infra-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 18px;
  }
  .infra-card {
    background: var(--paper);
    border: 1px solid var(--rule-2);
    border-radius: 10px;
    padding: 20px 22px;
    display: flex;
    flex-direction: column;
    color: var(--ink);
    position: relative;
  }
  .infra-card-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .infra-card-num {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: 0.12em;
  }
  .infra-card-kicker {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--sage);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
  }

  /* Hardware card */
  .laptop-svg-wrap {
    width: 100%;
    text-align: center;
    margin: 6px 0 14px;
    color: var(--ink);
  }
  .laptop-svg {
    width: 160px;
    height: auto;
    max-width: 100%;
  }
  .hw-name {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-bottom: 2px;
  }
  .hw-chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    background: var(--sage-soft);
    color: var(--sage);
    border: 1px solid var(--sage);
    padding: 1px 7px;
    border-radius: 4px;
    vertical-align: middle;
    margin-left: 4px;
    letter-spacing: 0.04em;
  }
  .hw-sub {
    font-size: 12px;
    color: var(--ink-2);
    margin-bottom: 16px;
  }
  .ram-block { margin-top: auto; }
  .ram-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 6px;
  }
  .ram-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .ram-total {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink);
    font-weight: 600;
  }
  .ram-bar {
    display: flex;
    height: 16px;
    width: 100%;
    border: 1px solid var(--rule-2);
    border-radius: 3px;
    overflow: hidden;
    background: repeating-linear-gradient(
      90deg,
      transparent 0 calc(100%/16 - 1px),
      var(--rule-2) calc(100%/16 - 1px) calc(100%/16)
    );
  }
  .ram-seg {
    height: 100%;
    border-right: 1px solid rgba(0,0,0,0.06);
  }
  .ram-seg:last-child { border-right: none; }
  .ram-model { background: var(--sage); }
  .ram-sys   { background: var(--clinic); }
  .ram-free  { background: transparent; }
  .ram-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-2);
  }
  .ram-lg { display: inline-flex; align-items: center; gap: 5px; }
  .ram-lg .sw {
    width: 10px; height: 10px;
    border: 1px solid var(--rule-2);
    display: inline-block;
  }
  .ram-lg .sw.model { background: var(--sage); border-color: var(--sage); }
  .ram-lg .sw.sys   { background: var(--clinic); border-color: var(--clinic); }
  .ram-lg .sw.free  { background: var(--paper); }

  /* Ollama + Model cards */
  .infra-glyph {
    width: 80px;
    height: 80px;
    margin: 6px auto 14px;
    color: var(--ink);
  }
  .infra-glyph svg { width: 100%; height: 100%; display: block; }
  .infra-name {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-bottom: 2px;
    text-align: center;
  }
  .infra-sub {
    font-size: 12px;
    color: var(--ink-2);
    margin-bottom: 14px;
    text-align: center;
    line-height: 1.5;
  }
  .infra-code {
    font-family: var(--font-mono);
    font-size: 11px;
    background: var(--bg-2);
    border: 1px solid var(--rule);
    border-radius: 5px;
    padding: 10px 12px;
    color: var(--ink);
    line-height: 1.7;
    overflow-x: auto;
    margin-bottom: 12px;
    white-space: pre;
  }
  .infra-code .cm {
    color: var(--sage);
    margin-right: 6px;
    user-select: none;
  }
  .infra-foot {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }
  .model-specs {
    margin-top: 4px;
    border-top: 1px dotted var(--rule-2);
  }
  .model-spec-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px dotted var(--rule-2);
    font-size: 12px;
  }
  .model-spec-row:last-child { border-bottom: none; }
  .ms-k {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .ms-v {
    color: var(--ink);
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  /* Reasoning strip */
  .infra-strip {
    margin-top: 22px;
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: stretch;
    gap: 12px;
    padding: 16px 18px;
    background: var(--sage-soft);
    border: 1px dashed var(--sage);
    border-radius: 8px;
  }
  .strip-step {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .strip-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--sage);
    font-weight: 600;
    letter-spacing: 0.06em;
    flex-shrink: 0;
    padding-top: 1px;
  }
  .strip-txt {
    font-size: 12.5px;
    color: var(--ink-2);
    line-height: 1.5;
  }
  .strip-txt strong { color: var(--ink); font-weight: 600; }
  .strip-txt code {
    font-family: var(--font-mono);
    font-size: 11px;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0 4px;
  }
  .strip-arr {
    color: var(--sage);
    font-size: 18px;
    align-self: center;
  }
  .infra-note {
    margin-top: 16px;
    font-size: 12.5px;
    color: var(--ink-2);
    line-height: 1.6;
    font-style: italic;
    text-align: center;
  }

  @media (max-width: 1100px) {
    .infra-grid { grid-template-columns: 1fr; }
    .infra-strip {
      grid-template-columns: 1fr;
    }
    .infra-strip .strip-arr {
      transform: rotate(90deg);
      justify-self: center;
    }
  }

  /* ══════════ GPT ROOM specific ══════════ */
  #room-gpt .room-head {
    flex-direction: column;
    gap: 0;
  }
  #room-gpt .room-title-block {
    width: 100%;
  }
  #room-gpt .room-lede {
    max-width: none;
  }
  .gpt-meta-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    width: 100%;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--rule);
  }
  .gpt-meta-cell {
    display: flex;
    flex-direction: column;
  }
  .gpt-meta-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 6px;
    font-weight: 500;
  }
  .gpt-meta-value {
    color: var(--ink);
    font-weight: 500;
    font-size: 13.5px;
    line-height: 1.5;
  }
  .gpt-meta-value.soft {
    color: var(--ink-2);
    font-weight: 400;
    font-size: 13px;
    line-height: 1.55;
  }
  #room-gpt .modes-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .mode-steps {
    list-style: none;
    counter-reset: step;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .mode-steps li {
    counter-increment: step;
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 10px;
    align-items: center;
    padding: 7px 12px;
    background: var(--bg);
    border: 1px dashed var(--rule-2);
    border-radius: 4px;
  }
  .mode-steps li::before {
    content: counter(step, decimal-leading-zero);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--sage);
    font-weight: 600;
    letter-spacing: 0.06em;
  }
  .mode-steps .step-k {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.35;
  }
  .modes-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .mode {
    background: var(--paper);
    border: 1px solid var(--rule-2);
    border-radius: 8px;
    padding: 24px;
    position: relative;
  }
  .mode-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 14px;
  }
  .mode-tag {
    margin-left: auto;
    margin-top: 4px;
    flex-shrink: 0;
  }
  .mode-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.1em;
  }
  .mode-name {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 500;
  }
  .mode-desc {
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .mode-spec {
    background: var(--bg);
    border: 1px dashed var(--rule-2);
    border-radius: 4px;
    padding: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-2);
    line-height: 1.8;
  }
  .mode-spec .k { color: var(--ink-3); }
  .mode-spec .v { color: var(--ink); font-weight: 500; }

  /* Tribunal profile */
  .profile-card {
    background: var(--paper);
    border: 1px solid var(--rule-2);
    border-radius: 8px;
    padding: 26px 28px;
    margin-top: 8px;
  }
  .profile-card h4 {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--sage);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-weight: 500;
  }
  .profile-traits {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 28px;
    font-size: 15px;
    color: var(--ink-2);
    line-height: 1.55;
  }
  .profile-traits .t::before {
    content: '—';
    color: var(--sage);
    margin-right: 10px;
    font-weight: 600;
  }

  /* ══════════ WEB SEARCH ROOM ══════════ */
  .sources-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 12px;
  }
  .source-card {
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 20px 22px;
  }
  .source-head {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 8px;
  }
  .source-name {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .source-acro {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .source-when {
    font-size: 12px;
    color: var(--ink-2);
    line-height: 1.55;
    margin-top: 6px;
    padding-top: 10px;
    border-top: 1px dotted var(--rule-2);
  }
  .source-when strong { color: var(--ink); font-weight: 600; }
  .source-tags {
    display: flex; gap: 6px; flex-wrap: wrap;
    margin-top: 10px;
  }

  /* ══════════ SUPABASE ROOM ══════════ */
  .schema {
    background: var(--paper);
    border: 1px solid var(--rule-2);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 14px;
  }
  .schema-title {
    background: var(--ink);
    color: var(--paper);
    padding: 11px 20px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .schema-title .dot {
    width: 8px; height: 8px;
    background: var(--sage);
    border-radius: 50%;
  }
  .schema-row {
    display: grid;
    grid-template-columns: 175px 95px 1fr;
    padding: 11px 20px;
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 14px;
    align-items: center;
    gap: 14px;
  }
  .schema-row:last-child { border-bottom: none; }
  .schema-row .col { color: var(--ink); font-weight: 500; }
