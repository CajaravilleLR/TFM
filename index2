<script>
(function(){
  // ── Routing ────────────────────────────────────────────────
  const ROOMS = [
    { id: 'room-demo',         name: 'A · Demo' },
    { id: 'room-rag',          name: 'C · RAG' },
    { id: 'room-gpt',          name: 'B · GPT Tutor' },
    { id: 'room-web',          name: 'D · Web search' },
    { id: 'room-supabase',     name: 'E · Supabase' },
    { id: 'room-dash',         name: 'F · Dashboard' },
    { id: 'room-conclusiones', name: 'G · Conclusiones' }
  ];

  const stage    = document.getElementById('stage');
  const backBtn  = document.getElementById('backBtn');
  const roomNav  = document.getElementById('roomNav');
  const navPrev  = document.getElementById('navPrev');
  const navNext  = document.getElementById('navNext');
  const crumb    = document.getElementById('crumb');
  const crumbHome= document.getElementById('crumbHome');

  function currentView() {
    return document.querySelector('.view.active');
  }

  function updateCrumb(target) {
    if (target === 'view-map' || !target) {
      crumb.innerHTML = '<a id="crumbHome">◐ Mapa del sistema</a>';
    } else {
      const room = ROOMS.find(r => r.id === target);
      const name = room ? room.name : '';
      crumb.innerHTML = '<a id="crumbHome2">◐ Mapa</a><span class="sep">›</span><span class="here">' + name + '</span>';
      const home2 = document.getElementById('crumbHome2');
      if (home2) home2.addEventListener('click', () => goTo('view-map'));
    }
  }

  function goTo(targetId) {
    const cur = currentView();
    if (!cur || cur.id === targetId) return;
    cur.classList.remove('active');
    cur.classList.add('zoom-out');
    setTimeout(() => cur.classList.remove('zoom-out'), 500);

    const next = document.getElementById(targetId);
    if (!next) return;
    next.classList.add('active');
    next.scrollTop = 0;

    const isMap = targetId === 'view-map';
    backBtn.classList.toggle('show', !isMap);
    roomNav.classList.toggle('show', !isMap);
    updateCrumb(targetId);

    // close drawer if open
    document.getElementById('drawerCriterios').classList.remove('open');
    document.getElementById('drawerClasificacion').classList.remove('open');

    // pause demo video when leaving the demo room
    if (cur.id === 'room-demo') {
      const v = document.getElementById('demoVideo');
      if (v) {
        const src = v.getAttribute('src');
        v.setAttribute('src', '');
        // restore on next frame so audio actually stops
        setTimeout(() => v.setAttribute('src', src), 50);
      }
    }
  }

  // node clicks — primary: data-target attribute
  document.querySelectorAll('.node[data-target]').forEach(node => {
    node.addEventListener('click', () => goTo(node.dataset.target));
  });

  // Belt-and-braces: event delegation. Even if individual listeners
  // were stripped by a sandbox / extension, clicks on any .node still
  // route via the closest .node[data-target] ancestor.
  document.addEventListener('click', (e) => {
    const node = e.target.closest('.node[data-target]');
    if (!node) return;
    // Avoid double-fire from the per-node listener — that one already
    // ran on the same event via bubbling. Use a flag:
    if (e.__navHandled) return;
    e.__navHandled = true;
    goTo(node.dataset.target);
  }, true);  // capture phase — wins over any later handlers

  const mapToConclusiones = document.getElementById('mapToConclusiones');
  if (mapToConclusiones) mapToConclusiones.addEventListener('click', () => goTo('room-conclusiones'));

  backBtn.addEventListener('click', () => goTo('view-map'));
  crumbHome.addEventListener('click', () => goTo('view-map'));

  // arrow nav between rooms
  function indexOfCurrent() {
    const id = currentView()?.id;
    return ROOMS.findIndex(r => r.id === id);
  }
  navPrev.addEventListener('click', () => {
    const i = indexOfCurrent();
    if (i > 0) goTo(ROOMS[i-1].id);
    else goTo('view-map');
  });
  navNext.addEventListener('click', () => {
    const i = indexOfCurrent();
    if (i >= 0 && i < ROOMS.length - 1) goTo(ROOMS[i+1].id);
  });

  // keyboard
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const drawer = document.getElementById('drawerCriterios');
      const drawerC = document.getElementById('drawerClasificacion');
      if (drawer.classList.contains('open')) {
        drawer.classList.remove('open');
        return;
      }
      if (drawerC.classList.contains('open')) {
        drawerC.classList.remove('open');
        return;
      }
      if (currentView()?.id !== 'view-map') goTo('view-map');
    }
    if (e.key === 'ArrowRight') {
      const i = indexOfCurrent();
      if (currentView()?.id === 'view-map') goTo(ROOMS[0].id);
      else if (i >= 0 && i < ROOMS.length - 1) goTo(ROOMS[i+1].id);
    }
    if (e.key === 'ArrowLeft') {
      const i = indexOfCurrent();
      if (i > 0) goTo(ROOMS[i-1].id);
      else if (i === 0) goTo('view-map');
    }
  });

  // ── Drawer (criterios) ─────────────────────────────────────
  const drawer = document.getElementById('drawerCriterios');
  function openDrawer(){ drawer.classList.add('open'); }
  function closeDrawer(){ drawer.classList.remove('open'); }
  document.getElementById('closeDrawer').addEventListener('click', closeDrawer);
  const openCriteriosColl = document.getElementById('openCriteriosFromColl');
  if (openCriteriosColl) openCriteriosColl.addEventListener('click', openDrawer);
  const openCriteriosTL = document.getElementById('openCriteriosFromTL');
  if (openCriteriosTL) openCriteriosTL.addEventListener('click', openDrawer);

  // ── Drawer (clasificación) ────────────────────────────────
  const drawerClasif = document.getElementById('drawerClasificacion');
  function openDrawerClasif(){ drawerClasif.classList.add('open'); }
  function closeDrawerClasif(){ drawerClasif.classList.remove('open'); }
  document.getElementById('closeDrawerClasif').addEventListener('click', closeDrawerClasif);
  document.getElementById('openClasifFromFase1').addEventListener('click', openDrawerClasif);
  document.getElementById('openClasifFromFase2').addEventListener('click', openDrawerClasif);

  // ── Animated packets along connections ────────────────────
  const svg = document.getElementById('mapSvg');
  const packetsG = document.getElementById('packets');
  const PATHS = [
    { id: 'p-user-gpt', dur: 2400, delay: 0,    color: 'var(--ink)' },
    { id: 'p-gpt-rag',  dur: 2200, delay: 600,  color: 'var(--sage)' },
    { id: 'p-gpt-web',  dur: 2600, delay: 900,  color: 'var(--clinic)' },
    { id: 'p-gpt-db',   dur: 2000, delay: 1300, color: 'var(--warn)' },
    { id: 'p-db-dash',  dur: 2400, delay: 1700, color: 'var(--warn)' },
    { id: 'p-dash-user',dur: 3400, delay: 2100, color: 'var(--sage)' }
  ];

  PATHS.forEach(p => {
    const path = document.getElementById(p.id);
    if (!path) return;

    const c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    c.setAttribute('r', '3.6');
    c.setAttribute('class', 'packet');
    c.setAttribute('fill', getComputedStyle(document.documentElement).getPropertyValue('--sage') || '#39a98a');
    packetsG.appendChild(c);

    const animate = () => {
      const len = path.getTotalLength();
      const start = performance.now();
      function tick(now) {
        const t = ((now - start) % p.dur) / p.dur;
        const pt = path.getPointAtLength(len * t);
        c.setAttribute('cx', pt.x);
        c.setAttribute('cy', pt.y);
        c.setAttribute('opacity', t < 0.05 || t > 0.95 ? '0' : '0.85');
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    };
    setTimeout(animate, p.delay);
  });

  // ── Live Supabase metric (best-effort) ────────────────────
  // Tries to read a publicly-displayed session count from the dashboard iframe.
  // Falls back to a stable placeholder.
  function setMetric(v) {
    document.querySelectorAll('[data-metric="sessions"]').forEach(el => el.textContent = v);
  }
  setMetric('en vivo');

  // ── Map canvas: NO dynamic scaling — Safari quirks with transform: scale
  //    cause click hit-boxes to misalign in fullscreen. Canvas stays at
  //    its native 1440×620 size; the wrap scrolls if the viewport is
  //    smaller. This trades visual scaling for click reliability.
  function fitMap() {
    const canvas = document.getElementById('mapCanvas');
    if (canvas) {
      canvas.style.transform = '';
      canvas.style.zoom = '';
      canvas.dataset.scale = '1';
    }
  }
  window.addEventListener('resize', fitMap);
  // Also re-fit on fullscreen change
  document.addEventListener('fullscreenchange', () => setTimeout(fitMap, 50));
  // ResizeObserver — catches fullscreen changes triggered by parent frames
  // (e.g. platform "Fullscreen" button) where fullscreenchange doesn't fire.
  if (typeof ResizeObserver !== 'undefined') {
    const ro = new ResizeObserver(() => fitMap());
    ro.observe(document.body);
    const wrap = document.querySelector('.map-canvas-wrap');
    if (wrap) ro.observe(wrap);
  }
  setTimeout(fitMap, 50);
  setTimeout(fitMap, 300);

  // ── Editable layout: drag nodes, redraw connections, persist ──
  // v2 keying — invalidates v1 layouts saved against the older 1280×560 canvas.
  const STORAGE_KEY = 'rag-ope-map-layout-v2';
  // Clean up old key from prior canvas size
  try { localStorage.removeItem('rag-ope-map-layout-v1'); localStorage.removeItem('mapLayout-v1'); } catch(e){}
  const canvas = document.getElementById('mapCanvas');
  const editBtn = document.getElementById('editBtn');
  const resetBtn = document.getElementById('resetLayoutBtn');

  // Connection map: each conn is between two nodes, with an upright label
  const NODE_W = 240; // approx node card width
  const NODE_H = 116; // approx node card height
  const CONNS = [
    { id: 'p-user-gpt',  from: 'user', to: 'gpt',  label: 'consulta',             side: 'h' },
    { id: 'p-gpt-rag',   from: 'gpt',  to: 'rag',  label: 'recupera',             side: 'diag' },
    { id: 'p-gpt-web',   from: 'gpt',  to: 'web',  label: 'actualiza',            side: 'diag' },
    { id: 'p-gpt-db',    from: 'gpt',  to: 'db',   label: 'registra',             side: 'h' },
    { id: 'p-db-dash',   from: 'db',   to: 'dash', label: 'log sesión',           side: 'diag' },
    { id: 'p-dash-user', from: 'dash', to: 'user', label: 'feedback de progreso', side: 'diag' }
  ];

  function nodeCenter(id) {
    const el = canvas.querySelector('.node[data-id="' + id + '"]');
    if (!el) return { x: 0, y: 0 };
    const x = parseFloat(el.style.left);
    const y = parseFloat(el.style.top);
    return { x, y };
  }

  // Trim a segment endpoint so it stops at the node edge (rectangle approx)
  function trim(a, b) {
    const dx = b.x - a.x, dy = b.y - a.y;
    const len = Math.hypot(dx, dy) || 1;
    const ux = dx / len, uy = dy / len;
    // intersect with axis-aligned rectangle around `a` of size NODE_W × NODE_H
    const hx = NODE_W / 2, hy = NODE_H / 2;
    const tx = ux !== 0 ? hx / Math.abs(ux) : Infinity;
    const ty = uy !== 0 ? hy / Math.abs(uy) : Infinity;
    const t = Math.min(tx, ty);
    return { x: a.x + ux * t, y: a.y + uy * t };
  }

  function redrawConns() {
    const labelsG = document.getElementById('connLabels');
    if (labelsG) labelsG.innerHTML = '';

    CONNS.forEach(c => {
      const path = document.getElementById(c.id);
      if (!path) return;
      const A = nodeCenter(c.from);
      const B = nodeCenter(c.to);
      const a = trim(A, B);
      const b = trim(B, A);

      let d, midX, midY, angleDeg = 0;
      if (c.side === 'arc') {
        // top arc that doesn't pass through GPT/RAG/Web
        const mx = (a.x + b.x) / 2;
        const my = Math.min(a.y, b.y) - 90;
        d = `M ${a.x} ${a.y} Q ${mx} ${my} ${b.x} ${b.y}`;
        midX = mx; midY = my + 6;
      } else {
        d = `M ${a.x} ${a.y} L ${b.x} ${b.y}`;
        midX = (a.x + b.x) / 2;
        midY = (a.y + b.y) / 2;
      }
      path.setAttribute('d', d);

      // Upright label — always horizontal text, with subtle background plate
      if (labelsG) {
        const padX = 6, padY = 3, fontSize = 10;
        const textW = c.label.length * 5.4 + padX * 2;
        const textH = fontSize + padY * 2;
        const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        rect.setAttribute('x', midX - textW / 2);
        rect.setAttribute('y', midY - textH / 2);
        rect.setAttribute('width', textW);
        rect.setAttribute('height', textH);
        rect.setAttribute('rx', '2');
        rect.setAttribute('fill', 'var(--bg)');
        rect.setAttribute('stroke', 'none');
        labelsG.appendChild(rect);

        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.setAttribute('x', midX);
        text.setAttribute('y', midY + 3.5);
        text.setAttribute('text-anchor', 'middle');
        text.setAttribute('class', 'conn-label');
        text.textContent = c.label;
        labelsG.appendChild(text);
      }
    });
  }

  function saveLayout() {
    const layout = {};
    canvas.querySelectorAll('.node').forEach(n => {
      layout[n.dataset.id] = { x: parseFloat(n.style.left), y: parseFloat(n.style.top) };
    });
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(layout)); } catch(e){}
  }

  function loadLayout() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const layout = JSON.parse(raw);
      Object.keys(layout).forEach(id => {
        const el = canvas.querySelector('.node[data-id="' + id + '"]');
        if (el) {
          el.style.left = layout[id].x + 'px';
          el.style.top  = layout[id].y + 'px';
        }
      });
    } catch(e){}
  }

  loadLayout();
  redrawConns();

  // Drag logic — only when in editing mode
  let dragging = null;
  let dragOffset = { x: 0, y: 0 };

  function onPointerDown(e) {
    if (!canvas.classList.contains('editing')) return;
    const node = e.currentTarget;
    e.preventDefault();
    dragging = node;
    node.classList.add('dragging');
    const rect = canvas.getBoundingClientRect();
    const scale = parseFloat(canvas.dataset.scale || '1') || 1;
    const px = (e.clientX - rect.left) / scale;
    const py = (e.clientY - rect.top) / scale;
    dragOffset.x = px - parseFloat(node.style.left);
    dragOffset.y = py - parseFloat(node.style.top);
    document.addEventListener('pointermove', onPointerMove);
    document.addEventListener('pointerup', onPointerUp, { once: true });
  }
  function onPointerMove(e) {
    if (!dragging) return;
    const rect = canvas.getBoundingClientRect();
    const scale = parseFloat(canvas.dataset.scale || '1') || 1;
    const px = (e.clientX - rect.left) / scale;
    const py = (e.clientY - rect.top) / scale;
    let nx = px - dragOffset.x;
    let ny = py - dragOffset.y;
    nx = Math.max(80, Math.min(1200, nx));
    ny = Math.max(60, Math.min(520, ny));
    dragging.style.left = nx + 'px';
    dragging.style.top  = ny + 'px';
    redrawConns();
  }
  function onPointerUp() {
    if (dragging) dragging.classList.remove('dragging');
    dragging = null;
    document.removeEventListener('pointermove', onPointerMove);
    saveLayout();
  }

  canvas.querySelectorAll('.node').forEach(n => {
    n.addEventListener('pointerdown', onPointerDown);
    // prevent click navigation while editing
    n.addEventListener('click', (e) => {
      if (canvas.classList.contains('editing')) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);
  });

  editBtn.addEventListener('click', () => {
    const editing = canvas.classList.toggle('editing');
    editBtn.classList.toggle('active', editing);
    editBtn.textContent = editing ? '✓ Listo · guardar' : '✎ Editar layout';
    resetBtn.style.display = editing ? 'inline-block' : 'none';
  });
  resetBtn.addEventListener('click', () => {
    try { localStorage.removeItem(STORAGE_KEY); } catch(e){}
    const defaults = {
      user: [200, 320], gpt: [720, 320], rag: [540, 90],
      web:  [900, 90],  db:  [1240, 320], dash: [720, 520]
    };
    Object.keys(defaults).forEach(id => {
      const el = canvas.querySelector('.node[data-id="' + id + '"]');
      if (el) {
        el.style.left = defaults[id][0] + 'px';
        el.style.top  = defaults[id][1] + 'px';
      }
    });
    redrawConns();
  });

  // ── Open YouTube in new window (works inside sandboxed previews) ──
  const ytBtn = document.getElementById('openYT');
  if (ytBtn) {
    ytBtn.addEventListener('click', () => {
      const url = 'https://www.youtube.com/watch?v=fJKmhsstDn8';
      const w = window.open(url, '_blank', 'noopener,noreferrer');
      if (!w) {
        // fallback: try top-level navigation
        try { window.top.location.href = url; }
        catch(e) { window.location.href = url; }
      }
    });
  }
})();
</script>

